[Unit]
Description=SFID Backend Service
After=network.target

[Service]
Type=simple
User=sfid
Group=sfid
WorkingDirectory=/opt/sfid
EnvironmentFile=/etc/sfid/sfid.env
ExecStart=/opt/sfid/bin/sfid-backend
Restart=always
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/sfid /etc/sfid
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
MemoryDenyWriteExecute=true

[Install]
WantedBy=multi-user.target
