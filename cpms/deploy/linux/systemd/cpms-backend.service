[Unit]
Description=CPMS Backend Service
After=network-online.target postgresql.service
Wants=network-online.target
Requires=postgresql.service

[Service]
Type=simple
User=cpms
Group=cpms
WorkingDirectory=/var/lib/cpms
EnvironmentFile=/etc/cpms/cpms-backend.env
ExecStart=/opt/cpms/bin/cpms-backend
Restart=always
RestartSec=3
LimitNOFILE=65535
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/cpms /var/backups/cpms

[Install]
WantedBy=multi-user.target
