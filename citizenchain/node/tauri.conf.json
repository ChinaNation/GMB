{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "citizenchain",
  "version": "1.0.0",
  "identifier": "org.citizenappchain.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "公民链",
        "width": 1360,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; frame-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; style-src 'self'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'none'; script-src 'self'; script-src-elem 'self' 'unsafe-inline'; script-src-attr 'none'; connect-src 'self' ws://127.0.0.1:9944 ws://localhost:9944 https://raw.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/256x256@2x.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["dmg", "nsis", "deb"],
    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "CITIZENCHAIN_TAURI_UPDATER_PUBKEY_NOT_CONFIGURED",
      "endpoints": [
        "https://github.com/ChinaNation/GMB/releases/latest/download/citizenchain-latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
