{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "citizenchain",
  "version": "0.1.0",
  "identifier": "org.chinanation.citizenchain.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "公民币区块链系统",
        "width": 1360,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; frame-src 'self' https://chinanation.github.io; img-src 'self' data:; style-src 'self'; style-src-attr 'none'; script-src 'self'; connect-src 'self' ws://127.0.0.1:9944 ws://localhost:9944 https://raw.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/256x256@2x.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/icon.png"
    ],
    "targets": "all",
    "externalBin": ["binaries/citizenchain-node"],
    "resources": ["binaries/citizenchain-node.sha256"]
  }
}
