{
  "name": "citizenapp-square-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "dev:local": "wrangler dev --local",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:local": "wrangler d1 execute citizenapp-square-db --local --file migrations/0001_square_core.sql",
    "db:staging": "wrangler d1 execute citizenapp-square-db-staging --env staging --remote --file migrations/0001_square_core.sql",
    "db:production": "wrangler d1 execute citizenapp-square-db-production --env production --remote --file migrations/0001_square_core.sql",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production"
  },
  "dependencies": {
    "@polkadot/util-crypto": "^14.0.3",
    "aws4fetch": "^1.0.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.114.0"
  }
}
